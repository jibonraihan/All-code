package Calculator;
import javax.swing.*;
import java.awt.*;
import java.awt.event.*;

public class registrationForm {
	 public static void main(String[] args) {

	        // Frame create
	        JFrame f = new JFrame("Registration Form");
	        f.setSize(400, 500);
	        f.setLayout(null);
	        f.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

	        // Title
	        JLabel title = new JLabel("Registration Form");
	        title.setBounds(100, 20, 200, 30);
	        title.setFont(new Font("Arial", Font.BOLD, 18));
	        f.add(title);

	        // Name
	        JLabel nm = new JLabel("Name:");
	        nm.setBounds(50, 80, 100, 25);
	        f.add(nm);

	        JTextField nmF = new JTextField();
	        nmF.setBounds(150, 80, 150, 25);
	        f.add(nmF);
	        
	        //father name
	        JLabel fname = new JLabel("Father Name:");
	        fname.setBounds(50, 120, 100, 25);
	        f.add(fname);

	        JTextField fnameF = new JTextField();
	        fnameF.setBounds(150, 120, 150, 25);
	        f.add(fnameF);

	        // Email
	        JLabel mailL = new JLabel("Email:");
	        mailL.setBounds(50, 160, 100, 25);
	        f.add(mailL);

	        JTextField mailF = new JTextField();
	        mailF.setBounds(150, 160, 150, 25);
	        f.add(mailF);
	        
	        JLabel addr = new JLabel("Address:");
	        addr.setBounds(50, 200, 100, 25);
	        f.add(addr);

	        JTextField addrF = new JTextField();
	        addrF.setBounds(150, 160, 150, 25);
	        f.add(addrF);

	        // Password
	        JLabel passL = new JLabel("Password:");
	        passL.setBounds(50, 240, 100, 25);
	        f.add(passL);

	        JPasswordField passF = new JPasswordField();
	        passF.setBounds(150, 240, 150, 25);
	        f.add(passF);

	        // Gender
	        JLabel genL = new JLabel("Gender:");
	        genL.setBounds(50, 280, 100, 25);
	        f.add(genL);

	        JRadioButton male = new JRadioButton("Male");
	        male.setBounds(150, 280, 70, 25);

	        JRadioButton female = new JRadioButton("Female");
	        female.setBounds(220, 280, 80, 25);

	        ButtonGroup bg = new ButtonGroup();
	        bg.add(male);
	        bg.add(female);

	        f.add(male);
	        f.add(female);

	        // Submit Button
	        JButton submit = new JButton("Register");
	        submit.setBounds(130, 280, 120, 30);
	        f.add(submit);

	        // Action
	        submit.addActionListener(new ActionListener() {
	            public void actionPerformed(ActionEvent e) {

	                String name = nmF.getText();
	                String email = mailF.getText();
	                String father = fnameF.getText();
	                String address = addrF.getText();
	                String pass = new String(passF.getPassword());

	                String gender = "";
	                if (male.isSelected()) {
	                    gender = "Male";
	                } else if (female.isSelected()) {
	                    gender = "Female";
	                }

	                JOptionPane.showMessageDialog(f,
	                        "Name: " + name +
	                        "\nFather name: "+father +
	                        "\nAddress: "+addrF +
	                        "\nEmail: " + email +
	                        "\nPassword: " + pass +
	                        "\nGender: " + gender);
	            }
	        });

	        f.setVisible(true);
	    }
}
