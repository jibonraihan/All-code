package Calculator;
import javax.swing.*;
import java.awt.*;
import java.awt.event.*;

public class registrationForm {
	 public static void main(String[] args) {

	        // Frame create
	        JFrame f = new JFrame("Registration Form");
	        f.setSize(400, 400);
	        f.setLayout(null);
	        f.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

	        // Title
	        JLabel title = new JLabel("Registration Form");
	        title.setBounds(100, 20, 200, 30);
	        title.setFont(new Font("Arial", Font.BOLD, 18));
	        f.add(title);

	        // Name
	        JLabel nameLabel = new JLabel("Name:");
	        nameLabel.setBounds(50, 80, 100, 25);
	        f.add(nameLabel);

	        JTextField nameField = new JTextField();
	        nameField.setBounds(150, 80, 150, 25);
	        f.add(nameField);

	        // Email
	        JLabel emailLabel = new JLabel("Email:");
	        emailLabel.setBounds(50, 120, 100, 25);
	        f.add(emailLabel);

	        JTextField emailField = new JTextField();
	        emailField.setBounds(150, 120, 150, 25);
	        f.add(emailField);

	        // Password
	        JLabel passLabel = new JLabel("Password:");
	        passLabel.setBounds(50, 160, 100, 25);
	        f.add(passLabel);

	        JPasswordField passField = new JPasswordField();
	        passField.setBounds(150, 160, 150, 25);
	        f.add(passField);

	        // Gender
	        JLabel genderLabel = new JLabel("Gender:");
	        genderLabel.setBounds(50, 200, 100, 25);
	        f.add(genderLabel);

	        JRadioButton male = new JRadioButton("Male");
	        male.setBounds(150, 200, 70, 25);

	        JRadioButton female = new JRadioButton("Female");
	        female.setBounds(220, 200, 80, 25);

	        ButtonGroup bg = new ButtonGroup();
	        bg.add(male);
	        bg.add(female);

	        f.add(male);
	        f.add(female);

	        // Submit Button
	        JButton submit = new JButton("Register");
	        submit.setBounds(130, 260, 120, 30);
	        f.add(submit);

	        // Action
	        submit.addActionListener(new ActionListener() {
	            public void actionPerformed(ActionEvent e) {

	                String name = nameField.getText();
	                String email = emailField.getText();
	                String pass = new String(passField.getPassword());

	                String gender = "";
	                if (male.isSelected()) {
	                    gender = "Male";
	                } else if (female.isSelected()) {
	                    gender = "Female";
	                }

	                JOptionPane.showMessageDialog(f,
	                        "Name: " + name +
	                        "\nEmail: " + email +
	                        "\nPassword: " + pass +
	                        "\nGender: " + gender);
	            }
	        });

	        f.setVisible(true);
	    }
}
